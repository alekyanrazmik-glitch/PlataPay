# ==========================================================================
# PlataPay — Enot payment integration
# ==========================================================================
# These variables belong to the payment backend in worker/ (a Cloudflare
# Worker) — NOT to the static site build (build.mjs has no server runtime
# and never sees secrets). Set real values as Cloudflare Worker secrets
# (see worker/README.md), never in a committed file.
#
# This file only documents the variable names — do not put real keys here.

# --- Enot merchant credentials (from your Enot dashboard) ---
ENOT_SHOP_ID=                 # "ID проекта" — your merchant/shop number
ENOT_SECRET_KEY=              # "Секретный ключ" — signs the payment link (md5)
ENOT_SECRET_KEY_2=            # "Дополнительный ключ" — verifies the webhook's sign_2
ENOT_API_KEY=                 # reserved for future use (balance/status API calls) — not required for the payment-link + webhook flow

# --- Redirect URLs (also set as the defaults in your Enot dashboard) ---
ENOT_SUCCESS_URL=https://payoplata.ru/payment/success/
ENOT_FAIL_URL=https://payoplata.ru/payment/fail/

# Informational: Enot's postback/webhook URL is configured once in the Enot
# dashboard (not sent per-request by this integration), point it at:
ENOT_WEBHOOK_URL=https://<your-worker-subdomain>.workers.dev/api/enot-webhook

# --- Telegram notification target for paid orders ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Public site URL ---
SITE_URL=https://payoplata.ru
