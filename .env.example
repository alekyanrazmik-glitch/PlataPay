# ================================================================
# PlataPay — переменные окружения
# Скопируйте этот файл в .env и заполните реальными значениями.
# Файл .env никогда не коммитится в git.
# ================================================================

# ---- Enot Payment Gateway ----
# Секретный ключ (для проверки подписи входящих webhook-уведомлений)
ENOT_SECRET_KEY=ВАШ_СЕКРЕТНЫЙ_КЛЮЧ

# Дополнительный ключ / API-ключ (для создания счетов через API)
ENOT_API_KEY=ВАШ_API_КЛЮЧ

# ID магазина в Enot (см. личный кабинет → Магазины)
ENOT_SHOP_ID=ВАШ_SHOP_ID

# ---- Адреса сервера ----
# Публичный URL сервера без слеша в конце (Railway выдаёт автоматически)
SERVER_URL=https://ваш-проект.up.railway.app

# Webhook-адрес для Enot (обычно SERVER_URL + /api/webhook/enot)
WEBHOOK_URL=https://ваш-проект.up.railway.app/api/webhook/enot

# Порт (Railway устанавливает сам, менять не нужно)
PORT=3000

# ---- Telegram-уведомления ----
# Токен бота (@BotFather)
TELEGRAM_BOT_TOKEN=0000000000:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA

# Chat ID куда слать уведомления (ваш личный или группы)
TELEGRAM_CHAT_ID=000000000
