# ================================================================
# PlataPay — переменные окружения
# Скопируйте этот файл в .env для локальной разработки.
# На Vercel добавьте эти же переменные через Settings → Environment Variables.
# Файл .env никогда не коммитится в git.
# ================================================================

# ---- Enot Payment Gateway ----
# Секретный ключ (для проверки HMAC-SHA256 подписи webhook)
ENOT_SECRET_KEY=ВАШ_СЕКРЕТНЫЙ_КЛЮЧ

# Дополнительный ключ / API-ключ (для создания счетов)
ENOT_API_KEY=ВАШ_API_КЛЮЧ

# ID магазина в Enot (Личный кабинет → Магазины)
ENOT_SHOP_ID=ВАШ_SHOP_ID

# ---- URL сайта ----
# На Vercel задайте вручную свой production-домен.
# В preview-деплоях URL автоматически берётся из переменной VERCEL_URL.
SERVER_URL=https://ваш-домен.vercel.app

# ---- Telegram-уведомления ----
TELEGRAM_BOT_TOKEN=0000000000:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA
TELEGRAM_CHAT_ID=000000000
