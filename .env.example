# ================================================================
# PlataPay — переменные окружения
# Локально: скопируйте этот файл в .env и заполните.
# На Timeweb Cloud: добавьте эти переменные в настройках приложения
# (App → Переменные окружения). Файл .env не коммитится в git.
# ================================================================

# ---- Enot Payment Gateway ----
# Секретный ключ (для проверки HMAC-SHA256 подписи webhook)
ENOT_SECRET_KEY=ВАШ_СЕКРЕТНЫЙ_КЛЮЧ

# Дополнительный ключ / API-ключ (для создания счетов)
ENOT_API_KEY=ВАШ_API_КЛЮЧ

# ID магазина в Enot (Личный кабинет → Магазины)
ENOT_SHOP_ID=ВАШ_SHOP_ID

# ---- Адреса сервера ----
# Публичный URL приложения без слеша в конце
SERVER_URL=https://ваш-домен.timeweb.cloud

# Webhook-адрес для Enot (обычно SERVER_URL + /api/webhook/enot)
WEBHOOK_URL=https://ваш-домен.timeweb.cloud/api/webhook/enot

# Порт. Timeweb Cloud прокидывает PORT автоматически; по умолчанию 3000.
PORT=3000

# ---- Telegram-уведомления ----
TELEGRAM_BOT_TOKEN=0000000000:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA
TELEGRAM_CHAT_ID=000000000
